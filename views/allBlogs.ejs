<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Blogs</title>

    <style>
        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
        }

        body{
            font-family: Georgia, "Times New Roman", serif;
            background:#0A0A0A;
            
            color:#e6e6e6;
            line-height:1.8;
        }

        .container{
            max-width:760px;
            margin:70px auto;
            padding:0 22px;
        }

        h1{
            font-size:46px;
            margin-bottom:40px;
            color:#f5f5f5;
        }

        ul{
            list-style:none;
        }

        li{
            border-bottom:1px solid #2a2a2a;
            padding:22px 0;
        }

        a{
            text-decoration:none;
            color:#f5f5f5;
            font-size:26px;
            font-weight:600;
        }

        a:hover{
            color:#9ca3af;
        }

        .read{
            display:block;
            margin-top:8px;
            font-family:Arial, sans-serif;
            font-size:14px;
            color:#9ca3af;
        }

        .title-row{
      display:flex;
       justify-content:space-between;
      align-items:center;
    font-size:46px;
      line-height:1.15;
        font-weight:700;
        margin-bottom:16px;
}

.new-blog-btn{
    display:inline-block;
    background:#f5f5f5;
    color:#0A0A0A;
    margin-top: 19px;
    text-decoration:none;
    padding:12px 20px;
    height: 50px;
    font-family:Arial, sans-serif;
    font-size:14px;
    margin-bottom:30px;
}

.new-blog-btn:hover{
    opacity:0.9;
}

.delete-btn{
    background:none;
    border:none;
    color:#792424da;
    cursor:pointer;
    font-size:14px;
}

        @media(max-width:600px){
            .container{
                margin:40px auto;
                padding:0 18px;
            }

            h1{
                font-size:36px;
            }

            a{
                font-size:22px;
            }
        }
    </style>
</head>

<body>
    <main class="container">
        <div style="display: flex; gap: 300px;">
        <h1>All Blogs</h1>
       <a href="/blogs/newblog" class="new-blog-btn">
    + Create New Blog
</a>
        </div>
        <ul>
            <% blogs.forEach((blog) => { %>
               <li>
    <div class="title-row">
        <a href="/blogs/readOne/<%= blog._id %>" style="font-size: 40px;">
            <%= blog.title %>
        </a>

        <form action="/blogs/delete/<%= blog._id %>" method="POST">
         
             <a class="read" href="/blogs/edit/<%= blog._id %>">
        Edit blog 
    </a>


            <button type="submit" class="delete-btn">
                Delete
            </button>
        </form>
    </div>

    <a class="read" href="/blogs/readOne/<%= blog._id %>">
        Read blog →
    </a>
   
</li>
            <% }) %>
        </ul>
    </main>
</body>
</html>