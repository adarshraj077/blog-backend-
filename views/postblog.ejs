<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Blog</title>

    <style>
        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
        }

        body{
            background:#0A0A0A;
            color:#e6e6e6;
            font-family:Georgia, "Times New Roman", serif;
        }

        .container{
            max-width:760px;
            margin:70px auto;
            padding:0 22px;
        }

        h1{
            font-size:46px;
            margin-bottom:40px;
            color:#f5f5f5;
        }

        form{
            display:flex;
            flex-direction:column;
            gap:20px;
        }

        input,
        textarea{
            width:100%;
            background:#141414;
            border:1px solid #2a2a2a;
            color:#e6e6e6;
            padding:16px;
            font-size:18px;
            font-family:inherit;
            outline:none;
        }

        input:focus,
        textarea:focus{
            border-color:#666;
        }

        textarea{
            min-height:300px;
            resize:vertical;
        }

        button{
            width:fit-content;
            background:#f5f5f5;
            color:#0A0A0A;
            border:none;
            padding:12px 24px;
            font-size:16px;
            cursor:pointer;
        }

        button:hover{
            opacity:0.9;
        }

        .back{
            display:inline-block;
            margin-bottom:30px;
            color:#9ca3af;
            text-decoration:none;
            font-family:Arial, sans-serif;
            font-size:14px;
        }
    </style>
</head>
<body>

    <div class="container">

        <a href="/blogs/read" class="back">
            ← Back to Blogs
        </a>

        <h1>Create New Blog</h1>

        <form action="/blogs/new" method="POST">

            <input
                type="text"
                name="title"
                placeholder="Blog Title"
                required
            >

            <input
                type="text"
                name="author"
                placeholder="Author Name"
                
            >

            <textarea
                name="content"
                placeholder="Write your blog..."
                required
            ></textarea>

            <button type="submit">
                Publish Blog
            </button>

        </form>

    </div>

</body>
</html>